MYSQL_PORT=3306

# 应用设置
DEBUG=True
HOST=0.0.0.0
PORT=5000
FLASK_ENV=development

# 可选：AI服务配置
AI_API_KEY=your-ai-service-api-key
AI_API_URL=https://api.aimodel.com/v1/detect